{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisModuleValidationReport",
  "type": "object",
  "required": ["feature_name", "passed", "errors", "warnings", "metrics"],
  "properties": {
    "feature_name": {
      "type": "string"
    },
    "passed": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "scenario_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_step_count": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
